{
  "name": "threelane",
  "version": "0.1.0",
  "private": true,
  "description": "Threelane — local screen + multi-cam recorder and reels/shorts editor",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:web": "THREELANE_WEB_ONLY=1 vite",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "build": "npm run typecheck && vite build",
    "dist": "npm run build && electron-builder --mac -c electron-builder.yml"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.5",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "dependencies": {
    "@types/node-forge": "^1.3.14",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.438.0",
    "node-forge": "^1.4.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "ws": "^8.20.0"
  }
}
